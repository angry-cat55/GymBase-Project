        <Edit id="edtSetFrom" taborder="25" left="133" top="483" width="101" height="26" maxlength="8" value="20250506" text="20250506"/>
        <Button id="btnSetToDate" taborder="15" text="setToDate" left="20" top="514" width="108" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineGray"/>
        <Edit id="edtSetTo" taborder="26" left="133" top="514" width="101" height="26" maxlength="8" value="20250518" text="20250518"/>
        <Button id="btnEnableTrue" taborder="11" text="enable true" left="264" top="452" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
        <Button id="btnEnableFalse" taborder="12" text="enable false" left="369" top="452" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
        <Button id="btnReadonlyTrue" taborder="13" text="readonly true" left="264" top="483" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
        <Button id="btnReadonlyFalse" taborder="14" text="readonly false" left="369" top="483" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
        <Button id="btnRequiredFalse" taborder="10" text="required false" left="369" top="514" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
        <Button id="btnRequiredTrue" taborder="9" text="required true" left="264" top="514" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
