<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="SampleCalendar" width="1020" height="1110" titletext="월/기간 달력" onload="Form_onload">
    <Layouts>
      <Layout height="1110" width="1020">
        <Div id="divCalFromTo" taborder="0" text="Div00" left="20" top="385" width="310" height="26" url="Cmm::CmmCalendarFromTo.xfdl"/>
        <Button id="btnInit" taborder="1" text="초기화" left="264" top="421" width="100" height="26" onclick="btnInit_onclick" cssclass="btn_WF_LineBlue"/>
