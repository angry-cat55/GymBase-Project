        <Button id="btnGetToDate" taborder="19" text="getToDate" left="20" top="452" width="108" height="26" onclick="btnInit_onclick" cssclass="btn_WF_FillGray"/>
        <Edit id="editToDate" taborder="21" left="133" top="452" width="101" height="26" readonly="true"/>
