<?xml version="1.0" encoding="utf-8"?>
<ENV version="2.1">
  <Environment themeid="theme::default" datatyperule="2.0" onload="Environment_onload">
    <ScreenDefinition>
      <Screen id="Desktop_screen" type="desktop"/>
    </ScreenDefinition>
    <Variables>
      <Variable id="Env_TargetForm"/>
    </Variables>
    <Cookies/>
    <httpheader/>
  </Environment>
  <Script type="xscript5.1"><![CDATA[
this.Environment_onload = function(obj:nexacro.Environment,e:nexacro.LoadEventInfo)
{
	var sRtn = nexacro.getEnvironmentVariable("Env_TargetForm");
	alert(sRtn);
	var appObj = nexacro.getApplication();
	alert(appObj.mainframe.WorkFrame.formurl);
	
	
};
]]></Script>
</ENV>
