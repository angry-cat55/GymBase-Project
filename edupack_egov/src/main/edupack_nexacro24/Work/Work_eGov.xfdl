        <Button id="btn05" taborder="17" text="코드 가져오기(IN)" left="303" top="70" width="154" height="30" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn05_onclick"/>
        <Button id="btn05_00" taborder="18" text="코드 가져오기(IN)" left="467" top="68" width="154" height="30" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn05_onclick"/>
        <Button id="btn05_00_00" taborder="19" text="코드 가져오기(IN)" left="637" top="68" width="154" height="30" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn05_onclick"/>
        <MaskEdit id="mskEmpId" taborder="20" left="470" top="168" width="230" height="32" format="AA-###" type="string"/>
        <Button id="btn06" taborder="21" text="사원 중복 췤" left="709" top="166" width="241" height="35" onclick="btn06_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[//사원조회
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction("svcGetEmp"//아이디
					 ,"SvcUrl::edu/getEmpList.do"// EduUrlLocal::selecr_emp.jsp
					 ,""//화면 데이터-->서버 전달 저장 처리 할 때 사용
					 ,"ds_emp=out_emp"//서버에서 전달되는 데이터를 화면에서 받을때 사용 조화사용
				 	 ,""//서버로 전달한 변수
					 ,"fnCallback");
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.transaction("svcGetEmpParam1"//아이디
					 ,"SvcUrl::edu/getEmpListParam1.do"// EduUrlLocal::selecr_emp.jsp
					 ,""//화면 데이터-->서버 전달 저장 처리 할 때 사용
					 ,"ds_emp=out_emp"//서버에서 전달되는 데이터를 화면에서 받을때 사용 조화사용
				 	 ,"paramDept="+this.divSearch.form.edtDeptCode.value  //서버로 전달한 변수
					 ,"fnCallback");
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction("svcGetEmpParam2"//아이디
					 ,"SvcUrl::edu/getEmpListParam2.do"
					 ,""//화면 데이터-->서버 전달 저장 처리 할 때 사용
					 ,"ds_emp=out_emp"//서버에서 전달되는 데이터를 화면에서 받을때 사용 조화사용
				 	 ,"paramDept="+this.divSearch.form.edtDeptCode.value +
					 " paramName=" + this.divSearch.form.edt01.value  //서버로 전달한 변수
					 ,"fnCallback");
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
			this.transaction("svcGetEmpParamDS"//아이디
					 ,"SvcUrl::edu/getEmpListParamDS.do"
					 ,"srcData=dsSearch"//화면 데이터-->서버 전달 저장 처리 할 때 사용
					 ,"ds_emp=out_emp"//서버에서 전달되는 데이터를 화면에서 받을때 사용 조화사용
				 	 ,""
					 ,"fnCallback");
};

this.Work_Emp_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
			this.transaction("svcOnloadEmp",
					 "SvcUrl::edu/edupack24_jsp/select_code.jsp",
					 "",
					 "ds_dept=out_dept ds_pos=out_pos ds_skill=out_skill ds_hobby=out_hobby",
					 "",
					 "fnCallback");
};

this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{		
		var arrCode = ["SKILL","HOBBY"];
		this.transaction("svcGetCodeParam",
					 "SvcUrl::edu/getCodeParam.do",
					 "",
					 "ds_skill=SKILL ds_hobby=HOBBY",
					 "paramCode="+ arrCode.toString(),
					 "fnCallback");
};

this.btn05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		var arrCode = ["SKILL","HOBBY"];
		this.transaction("svcGetCodeIn",
					 "SvcUrl::edu/getCodeIn.do",
					 "",
					 "ds_pos=out_code",
					 "paramCode="+ arrCode.toString(),
					 "fnCallback");
};



this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.ds_emp.addRow();
};

this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.ds_emp.deleteRow(this.ds_emp.rowposition);
};

this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.transaction("svcSaveEmp",
					 "SvcUrl::edu/saveEmp.do",
					 "out_emp=ds_emp:u",
					 "",
					 "",
					 "fnCallback");
};

this.fnCallback=function(srvId,errCd,errMsg){
	if(errCd<0){
		alert("error!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!:"+ errMsg);
	}
	
	if(srvId=="svcCheckId"){
		alert(this.emp_count);
	//	alert(errCd+":"+errMsg);
	}
};

this.emp_count="";

this.btn06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction("svcCheckId",
					 "SvcUrl::edu/checkId.do",
					 "",
					 "",
					 "paramEmpId="+this.mskEmpId.value,
					 "fnCallback");
};
]]></Script>
    <Objects>
      <Dataset id="ds00"/>
      <Dataset id="ds_emp" useclientlayout="false">
        <ColumnInfo>
          <Column id="EMP_ID" type="STRING" size="256"/>
          <Column id="EMP_NAME" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_dept">
        <ColumnInfo>
          <Column id="DEPT_CODE" type="string" size="255"/>
          <Column id="DEPT_NAME" type="string" size="255"/>
          <Column id="DEPT_EMP" type="string" size="255"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_pos">
        <ColumnInfo>
          <Column id="CODE" type="STRING" size="256"/>
          <Column id="NAME" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_skill">
        <ColumnInfo>
          <Column id="CODE" type="string" size="255"/>
          <Column id="NAME" type="string" size="255"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_hobby">
        <ColumnInfo>
          <Column id="CODE" type="STRING" size="256"/>
          <Column id="NAME" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_emp00">
        <ColumnInfo>
          <Column id="EMP_NAME" type="STRING" size="50"/>
          <Column id="EMP_ID" type="STRING" size="10"/>
          <Column id="DEPT_CODE" type="STRING" size="256"/>
          <Column id="POSITION" type="STRING" size="10"/>
