                      <Col id="datacolumn">여자</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btn00" taborder="8" text="사원 조회" left="219" top="8" width="141" height="30" onclick="btn00_onclick" borderRadius="100px" background="linear-gradient(#000000 0%,#ffffff 100%)"/>
        <Button id="btn01" taborder="9" text="파라메터 전달 1" left="372" top="5" width="109" height="35" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn01_onclick"/>
        <Button id="btn02" taborder="10" text="파라메터 전달 2" left="488" top="10" width="165" height="22" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn02_onclick"/>
        <Button id="btn03" taborder="11" text="파라메터 전달 2" left="666" top="7" width="154" height="30" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn03_onclick"/>
        <Button id="btn04" taborder="12" text="파라메터 전달 2" left="157" top="68" width="154" height="30" borderRadius="50px" background="linear-gradient(#000000 0%,#ffffff 52%,#000000 100%)" onclick="btn04_onclick"/>
        <Grid id="grd02" taborder="13" left="676" top="201" width="171" height="89" binddataset="ds_dept">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row band="head" size="24"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="DEPT_CODE"/>
                <Cell col="1" text="DEPT_NAME"/>
                <Cell col="2" text="DEPT_EMP"/>
              </Band>
              <Band id="body">
                <Cell text="bind:DEPT_CODE"/>
                <Cell col="1" text="bind:DEPT_NAME"/>
                <Cell col="2" text="bind:DEPT_EMP"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grd02_00" taborder="14" left="952" top="192" width="171" height="89" binddataset="ds_pos">
